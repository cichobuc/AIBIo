# Required — app refuses to start without these
ANTHROPIC_API_KEY=
AIBIO_ENCRYPTION_KEY=   # 32-byte base64: openssl rand -base64 32

# Optional — defaults shown
AIBIO_DB_PATH=./aibio.db
NODE_ENV=development

# MCP server credentials (Claude Code development environment)
GITHUB_TOKEN=            # github.com → Settings → Developer settings → PAT
POSTGRES_URL=            # postgresql://user:password@localhost:5432/dbname
MOTHERDUCK_TOKEN=        # app.motherduck.com → Settings → Access tokens (optional, for cloud DuckDB)
